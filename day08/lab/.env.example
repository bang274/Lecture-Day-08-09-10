# Day 08 Lab — Optimized RAG Pipeline (Sprint 1 & 2)
# Copy file này thành .env và điền API key

# === Jina AI (Embeddings & Reranker) ===
# Lấy key tại https://jina.ai/
JINA_API_KEY=your_jina_api_key_here

# === LLM Provider (Groq / Moonshot) ===
# Dùng Groq: https://console.groq.com/
# Dùng Kimi: https://platform.moonshot.cn/
GROQ_API_KEY=your_groq_or_kimi_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=moonshotai/kimi-k2-instruct


# === Local Persistence ===
# Thư mục lưu trữ vector database
# CHROMA_DB_DIR=./chroma_db
